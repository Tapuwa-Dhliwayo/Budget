<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ra_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_data_ownership_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_expense_filter_panel"
            android:padding="16dp"
            android:textColor="@color/ra_text"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/text_backup_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_expense_filter_panel"
            android:padding="16dp"
            android:textColor="@color/ra_text"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_create_local_backup"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:text="Create local backup" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Backups are copied to app-controlled local storage. Keep a separate device backup if you need protection against device loss or app uninstall."
            android:textColor="@color/ra_text_muted"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
