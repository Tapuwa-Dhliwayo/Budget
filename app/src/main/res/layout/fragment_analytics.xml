<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ra_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/text_analytics_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Damage Report"
        style="@style/RaText.ScreenTitle" />

    <TextView
        android:id="@+id/text_analytics_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="See which categories are draining shield strength this run"
        android:textColor="@color/ra_text_muted" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/ra_surface_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/ra_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/text_total_spent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textColor="@color/ra_text"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/text_budget_health"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/ra_text_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/text_top_insight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/ra_text_muted"
                android:textSize="14sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_categories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/text_empty_analytics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No damage logged yet. Add a spend to generate pressure intel."
        android:textColor="@color/ra_text_muted"
        android:gravity="center"
        android:visibility="gone"
        android:padding="12dp" />

</LinearLayout>
