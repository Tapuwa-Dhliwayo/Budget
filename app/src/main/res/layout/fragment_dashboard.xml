<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Month -->
        <TextView
            android:id="@+id/text_month"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- Budget Progress -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_budget"
            android:layout_width="200dp"
            android:layout_height="200dp"
            app:indicatorSize="200dp"
            app:trackThickness="12dp"
            app:indicatorColor="@color/teal_700"
            app:trackColor="@color/gray_light"
            android:layout_gravity="center_horizontal" />

        <!-- Budget Numbers -->
        <TextView
            android:id="@+id/text_budget_summary"
            android:layout_marginTop="12dp"
            android:textAlignment="center"
            android:textSize="16sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Top Categories -->
        <TextView
            android:id="@+id/text_top_categories"
            android:text="Top Categories"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/text_empty_categories"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/layout_top_categories"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Gamification -->
        <TextView
            android:id="@+id/text_streak"
            android:layout_marginTop="24dp"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>
</ScrollView>
