<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_canvas"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Month -->
            <TextView
                android:id="@+id/text_month"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ink_primary"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Budget Progress -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                app:cardBackgroundColor="@color/surface_panel"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_border"
                app:strokeWidth="1dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_budget"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    app:indicatorSize="200dp"
                    app:trackThickness="12dp"
                    app:indicatorColor="@color/accent_blue"
                    app:trackColor="@color/gray_light"
                    android:layout_gravity="center_horizontal" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Budget Numbers -->
            <TextView
                android:id="@+id/text_budget_summary"
                android:layout_marginTop="12dp"
                android:textAlignment="center"
                android:textSize="16sp"
                android:textColor="@color/ink_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- ✅ Edit Budget Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_budget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Budget"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp" />

            <!-- ✅ Month Comparison -->
            <TextView
                android:id="@+id/text_month_comparison"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textAlignment="center"
                android:textSize="14sp"
                android:textColor="@color/ink_secondary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface_panel"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Weekly Allowance"
                        android:textColor="@color/ink_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_weekly_allowance_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/ink_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/text_weekly_allowance_guidance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/ink_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_weekly_category_pressure"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/ink_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/text_weekly_recovery_actions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/text_weekly_review"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/ink_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_weekly_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/ink_tertiary"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_weekly_review"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Complete Review" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_weekly_summary"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Summary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_weekly_category_limits"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category Limits" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_edit_weekly_allowance"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                        android:text="Set Allowance" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ✅ Daily Spending Trend -->
            <TextView
                android:text="Daily Spending (Last 7 Days)"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/ink_primary"
                android:layout_marginTop="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/layout_daily_trend"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- ✅ Category Breakdown -->
            <TextView
                android:text="Category Breakdown"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/ink_primary"
                android:layout_marginTop="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/layout_category_pie"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Top Categories -->
            <TextView
                android:id="@+id/text_top_categories"
                android:text="Top Categories"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/ink_primary"
                android:layout_marginTop="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/text_empty_categories"
                android:text="No expenses yet"
                android:visibility="gone"
                android:textColor="@color/ink_secondary"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/layout_top_categories"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
