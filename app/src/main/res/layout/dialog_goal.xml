<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <EditText
            android:id="@+id/input_goal_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Goal name"
            android:inputType="textCapWords" />

        <Spinner
            android:id="@+id/spinner_goal_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/input_goal_target_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Target amount"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/input_goal_current_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Already saved"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/input_goal_target_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Target date: yyyy-MM-dd"
            android:inputType="date" />

        <EditText
            android:id="@+id/input_goal_monthly_target"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Monthly contribution target"
            android:inputType="numberDecimal" />

        <Spinner
            android:id="@+id/spinner_goal_priority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/input_goal_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Notes"
            android:inputType="textMultiLine"
            android:minLines="2" />
    </LinearLayout>
</ScrollView>
