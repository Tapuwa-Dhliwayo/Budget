<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ra_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_weekly_review_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weekly Debrief"
            style="@style/RaText.ScreenTitle" />

        <TextView
            android:id="@+id/text_weekly_review_overview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/ra_text"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/text_weekly_review_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/ra_text_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/text_weekly_review_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/ra_text_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/text_weekly_review_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/ra_text_muted"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Run History"
            style="@style/RaText.SectionTitle"
            android:textAllCaps="false" />

        <LinearLayout
            android:id="@+id/layout_weekly_trend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
