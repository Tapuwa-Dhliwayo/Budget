<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/surface_panel"
    app:cardElevation="0dp"
    app:cardCornerRadius="8dp"
    app:strokeColor="@color/surface_border"
    app:strokeWidth="1dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Category Icon -->
        <TextView
            android:id="@+id/text_category_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="24sp"
            android:background="@drawable/bg_expense_icon"
            android:textColor="@color/ink_primary"
            android:layout_marginEnd="16dp" />

        <!-- Description + Meta -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_description"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/ink_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/text_category"
                android:textSize="14sp"
                android:textColor="@color/ink_tertiary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/text_date"
                android:textSize="12sp"
                android:textColor="@color/ink_tertiary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/text_recurring"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingEnd="8dp"
                android:paddingBottom="2dp"
                android:background="@drawable/bg_expense_badge_recurring"
                android:text="Recurring"
                android:textColor="@color/accent_blue"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Amount + Photo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/text_amount"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/red_700"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <ImageView
                android:id="@+id/icon_photo"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_photo"
                android:visibility="gone"
                app:tint="@color/ink_tertiary" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
