<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_canvas"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Month Title -->
            <TextView
                android:id="@+id/text_month"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/ink_primary"
                android:layout_marginBottom="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Budget Overview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_panel"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:text="Budget Overview"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/ink_primary"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/text_total_spent"
                        android:textSize="16sp"
                        android:textColor="@color/ink_secondary"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/text_total_budget"
                        android:textSize="16sp"
                        android:textColor="@color/ink_secondary"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/text_remaining"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/ink_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Category Breakdown -->
            <TextView
                android:text="Category Breakdown"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ink_primary"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/container_categories"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Top 3 Categories -->
            <TextView
                android:text="Top Spending Categories"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ink_primary"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/text_top_categories"
                android:textSize="16sp"
                android:textColor="@color/ink_secondary"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Gamification Stats -->
            <TextView
                android:text="Your Progress"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ink_primary"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/text_streak"
                android:textSize="16sp"
                android:textColor="@color/ink_secondary"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/text_badges"
                android:textSize="16sp"
                android:textColor="@color/ink_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
