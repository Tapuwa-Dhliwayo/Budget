<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Command Center"
            style="@style/RaText.SectionTitle"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/ra_inner_panel_bg"
            android:padding="14dp"
            android:text="Review progress, check patterns, and manage your local recovery base."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_expense_filter_panel"
            android:orientation="vertical"
            android:padding="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_summary"
                style="@style/RaButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:text="Monthly Intel"
                android:textColor="?attr/colorOnSurface"
                app:icon="@android:drawable/ic_menu_month"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_weekly_review"
                style="@style/RaButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:text="Weekly Debrief"
                android:textColor="?attr/colorOnSurface"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_analytics"
                style="@style/RaButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:text="Damage Report"
                android:textColor="?attr/colorOnSurface"
                app:icon="@android:drawable/ic_menu_sort_by_size"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_net_worth"
                style="@style/RaButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:text="Net Worth Meter"
                android:textColor="?attr/colorOnSurface"
                app:icon="@android:drawable/ic_menu_compass"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_extra_income"
                style="@style/RaButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:text="Bonus Credits"
                android:textColor="?attr/colorOnSurface"
                app:icon="@android:drawable/ic_menu_upload"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_goals"
                style="@style/RaButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:text="Resource Vaults"
                android:textColor="?attr/colorOnSurface"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_recovery_progress"
                style="@style/RaButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:text="Recovery XP"
                android:textColor="?attr/colorOnSurface"
                app:icon="@android:drawable/ic_menu_upload"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Local Base"
            style="@style/RaText.SectionTitle"
            android:textAllCaps="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_expense_filter_panel"
            android:orientation="vertical"
            android:padding="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_profile"
                style="@style/RaButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:text="Pilot Profile"
                android:textColor="?attr/colorOnSurface"
                app:icon="@drawable/ic_profile"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_data_ownership"
                style="@style/RaButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:text="Data Vault"
                android:textColor="?attr/colorOnSurface"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
