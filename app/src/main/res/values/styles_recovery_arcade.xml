<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="RaText">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/ra_text</item>
    </style>

    <style name="RaText.ScreenTitle" parent="RaText">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ra_text</item>
    </style>

    <style name="RaText.SectionTitle" parent="RaText">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/ra_primary_soft</item>
    </style>

    <style name="RaText.Body" parent="RaText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/ra_text</item>
    </style>

    <style name="RaText.Muted" parent="RaText">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/ra_text_muted</item>
    </style>

    <style name="RaText.Metric" parent="RaText">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ra_text</item>
    </style>

    <style name="RaContainer" />

    <style name="RaContainer.Card" parent="RaContainer">
        <item name="android:background">@drawable/ra_card_bg</item>
        <item name="android:padding">18dp</item>
    </style>

    <style name="RaChip">
        <item name="android:background">@drawable/ra_chip_bg</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/ra_text_muted</item>
    </style>

    <style name="RaButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">@color/ra_border</item>
        <item name="android:textColor">@color/ra_text</item>
        <item name="iconTint">@color/ra_text_muted</item>
    </style>

    <style name="RaButton.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/ra_primary_soft</item>
        <item name="iconTint">@color/ra_primary_soft</item>
    </style>

    <style name="RaButton.Filled" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:backgroundTint">@color/ra_primary</item>
        <item name="android:textColor">@color/ra_bg</item>
        <item name="iconTint">@color/ra_bg</item>
    </style>

    <style name="RaTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/ra_surface_deep</item>
        <item name="boxStrokeColor">@color/ra_border</item>
        <item name="boxStrokeErrorColor">@color/ra_danger</item>
        <item name="hintTextColor">@color/ra_text_muted</item>
        <item name="android:textColorHint">@color/ra_text_muted</item>
    </style>

    <style name="RaEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/ra_text</item>
        <item name="android:textColorHint">@color/ra_text_muted</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
    </style>

    <style name="RaFab" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/ra_primary</item>
        <item name="tint">@color/ra_bg</item>
        <item name="rippleColor">@color/ra_primary_soft</item>
    </style>

</resources>
