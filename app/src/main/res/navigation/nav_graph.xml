<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <!-- Dashboard -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.budgettracker.ui.dashboard.DashboardFragment"
        android:label="Dashboard">

        <action
            android:id="@+id/action_dashboard_to_analytics"
            app:destination="@id/analyticsFragment" />
    </fragment>

    <fragment
        android:id="@+id/weeklyReviewSummaryFragment"
        android:name="com.example.budgettracker.ui.weekly.WeeklyReviewSummaryFragment"
        android:label="Weekly Review" />

    <!-- Expenses -->
    <fragment
        android:id="@+id/expenseListFragment"
        android:name="com.example.budgettracker.ui.expenses.ExpenseListFragment"
        android:label="Expenses">

        <action
            android:id="@+id/action_expenseList_to_addExpense"
            app:destination="@id/addExpenseFragment" />
    </fragment>

    <!-- Add / Edit Expense (NOT a bottom tab) -->
    <fragment
        android:id="@+id/addExpenseFragment"
        android:name="com.example.budgettracker.ui.expenses.AddExpenseFragment"
        android:label="Add Expense" />

    <!-- Categories -->
    <fragment
        android:id="@+id/categoryListFragment"
        android:name="com.example.budgettracker.ui.categories.CategoryListFragment"
        android:label="Categories" />

    <fragment
        android:id="@+id/debtBossFragment"
        android:name="com.example.budgettracker.ui.debt.DebtBossFragment"
        android:label="Debt Bosses" />

    <fragment
        android:id="@+id/moreFragment"
        android:name="com.example.budgettracker.ui.more.MoreFragment"
        android:label="More" />

    <fragment
        android:id="@+id/netWorthFragment"
        android:name="com.example.budgettracker.ui.networth.NetWorthFragment"
        android:label="Net Worth" />

    <fragment
        android:id="@+id/extraIncomeFragment"
        android:name="com.example.budgettracker.ui.extraincome.ExtraIncomeFragment"
        android:label="Extra Income" />

    <fragment
        android:id="@+id/goalsFragment"
        android:name="com.example.budgettracker.ui.goals.GoalsFragment"
        android:label="Goals" />

    <fragment
        android:id="@+id/gamificationFragment"
        android:name="com.example.budgettracker.ui.gamification.GamificationFragment"
        android:label="Recovery Progress" />

    <fragment
        android:id="@+id/dataOwnershipFragment"
        android:name="com.example.budgettracker.ui.privacy.DataOwnershipFragment"
        android:label="Data Ownership" />

    <!-- Summary -->
    <fragment
        android:id="@+id/summaryFragment"
        android:name="com.example.budgettracker.ui.summary.SummaryFragment"
        android:label="Summary" />

    <!-- Analytics (drill-down, not a tab) -->
    <fragment
        android:id="@+id/analyticsFragment"
        android:name="com.example.budgettracker.ui.analytics.AnalyticsFragment"
        android:label="Analytics" />

    <!-- Profile -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.budgettracker.ui.profile.ProfileFragment"
        android:label="Profile" />

</navigation>
