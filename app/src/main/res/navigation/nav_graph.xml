<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.budgettracker.ui.dashboard.DashboardFragment"
        android:label="Dashboard">

        <action
            android:id="@+id/action_dashboard_to_analytics"
            app:destination="@id/analyticsFragment" />

        <action
            android:id="@+id/action_dashboard_to_profile"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/expenseListFragment"
        android:name="com.example.budgettracker.ui.expenses.ExpenseListFragment"
        android:label="Expenses">
        <action
            android:id="@+id/action_expenseList_to_addExpense"
            app:destination="@id/addExpenseFragment" />

        <action
            android:id="@+id/action_expenses_to_profile"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/addExpenseFragment"
        android:name="com.example.budgettracker.ui.expenses.AddExpenseFragment"
        android:label="Add Expense" />

    <fragment
        android:id="@+id/categoryListFragment"
        android:name="com.example.budgettracker.ui.categories.CategoryListFragment"
        android:label="Categories">

        <action
            android:id="@+id/action_categories_to_profile"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/summaryFragment"
        android:name="com.example.budgettracker.ui.summary.SummaryFragment"
        android:label="Summary">

        <action
            android:id="@+id/action_summary_to_profile"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/analyticsFragment"
        android:name="com.example.budgettracker.ui.analytics.AnalyticsFragment"
        android:label="Analytics" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.budgettracker.ui.profile.ProfileFragment"
        android:label="Profile" />

</navigation>